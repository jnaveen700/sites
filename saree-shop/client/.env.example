# Client Environment Configuration
# VITE_API_BASE_URL: API endpoint for backend calls
# For development: http://localhost:5000/api
# For production: /api (uses same domain) or https://yourdomain.com/api

VITE_API_BASE_URL=/api

# Optional: Specify a custom proxy target for dev server
# VITE_DEV_API_PROXY_TARGET=http://localhost:5000
